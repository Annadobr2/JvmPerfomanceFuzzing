# Скопируйте этот файл в .env и заполните значения
# cp .env.example .env
#
# Эти переменные переопределяют соответствующие поля setting.json.
# Остальные параметры (temperature, maxTokens, timeoutSeconds) задаются в setting.json.

LLM_PROVIDER=OPENAI
LLM_API_KEY=...
LLM_BASE_URL=...
LLM_MODEL=gpt-5.4-mini
